# Server
PORT=8084
APP_ENV=development
# Optional API key for authenticating endpoints (leave empty to disable)
API_KEY=

# Database (provide either individual fields or DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=postgres
DB_SSLMODE=require
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Webhook verification (Svix signing secret from Resend)
WEBHOOK_SECRET=whsec_REPLACE_ME

# Resend API key for sending emails
RESEND_API_KEY=re_REPLACE_ME

# Cloudflare API token for setting up DNS records
CLOUDFLARE_API_TOKEN=cf_REPLACE_ME

# Reply token time-to-live in days (default: 90)
REPLY_TOKEN_TTL_DAYS=90

# CORS allowed origins (comma-separated, default: * for self-hosted)
CORS_ORIGINS=*

# Rate limit: max requests per minute per IP (default: 60)
RATE_LIMIT=60

# Webhook URL of this server for automatically registering with Resend (e.g. https://smee.io/your-id or https://your-domain.com)
# Leave empty to skip automatic Resend webhook setup
WEBHOOK_URL=

# Global brand name suffix used in forwarded emails (default: Veilo)
VIA_BRAND_NAME=Veilo

